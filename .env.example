# =============================================================================
# 王者之奕 - 环境变量配置示例
# =============================================================================
# 复制此文件为 .env 并修改配置
# cp .env.example .env
#
# 注意：
# 1. .env 文件不应提交到版本控制（已在 .gitignore 中）
# 2. 生产环境请使用强密码和密钥
# 3. 敏感信息建议使用 Docker Secrets 或 Vault
# =============================================================================

# -----------------------------------------------------------------------------
# 应用基础配置
# -----------------------------------------------------------------------------
# 运行环境: development | staging | production | testing
APP_ENV=development

# 调试模式（生产环境必须为 false）
DEBUG=true

# 应用名称和版本
APP_NAME=王者之奕
APP_VERSION=0.1.0

# -----------------------------------------------------------------------------
# 服务器配置
# -----------------------------------------------------------------------------
# 服务器绑定地址（0.0.0.0 表示所有接口）
SERVER_HOST=0.0.0.0

# 服务器端口
SERVER_PORT=8000

# 工作进程数（建议 2 * CPU 核心数）
SERVER_WORKERS=2

# 请求超时（秒）
SERVER_TIMEOUT=120

# -----------------------------------------------------------------------------
# 安全配置（生产环境必须修改！）
# -----------------------------------------------------------------------------
# 应用密钥：用于签名 JWT Token 等
# 生成方式: openssl rand -hex 32
# 注意：生产环境必须使用强密钥（至少 32 字符）
SECRET_KEY=your-secret-key-change-in-production-min-32-chars!!

# 访问令牌过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 刷新令牌过期时间（天）
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS 配置（允许的来源，逗号分隔，* 表示所有）
CORS_ORIGINS=*

# 速率限制（每分钟请求数，0 表示不限制）
RATE_LIMIT_PER_MINUTE=60

# -----------------------------------------------------------------------------
# MySQL 数据库配置
# -----------------------------------------------------------------------------
# 数据库主机地址（Docker 环境使用服务名）
DB_HOST=mysql

# 数据库端口
DB_PORT=3306

# 数据库名称
DB_NAME=wangzhe

# 数据库用户名
DB_USER=wangzhe

# 数据库密码（生产环境必须修改！）
DB_PASSWORD=your-secure-db-password-change-me

# MySQL root 密码（仅用于初始化，生产环境必须修改！）
MYSQL_ROOT_PASSWORD=your-secure-root-password-change-me

# 连接池大小
DB_POOL_SIZE=10

# 最大溢出连接数
DB_MAX_OVERFLOW=20

# 是否打印 SQL（调试用）
DB_ECHO=false

# -----------------------------------------------------------------------------
# Redis 配置
# -----------------------------------------------------------------------------
# Redis 主机地址（Docker 环境使用服务名）
REDIS_HOST=redis

# Redis 端口
REDIS_PORT=6379

# Redis 密码（可选，生产环境建议设置）
REDIS_PASSWORD=

# Redis 数据库编号（0-15）
REDIS_DB=0

# 最大连接数
REDIS_MAX_CONNECTIONS=50

# -----------------------------------------------------------------------------
# 游戏配置
# -----------------------------------------------------------------------------
# 每个房间最大玩家数
GAME_MAX_PLAYERS_PER_ROOM=8

# 游戏帧率（FPS）
GAME_TICK_RATE=30

# 回合持续时间（秒）
GAME_ROUND_DURATION_SECONDS=30

# 购买阶段持续时间（秒）
GAME_BUY_PHASE_DURATION=30

# 战斗阶段持续时间（秒）
GAME_BATTLE_PHASE_DURATION=60

# 初始金币
GAME_STARTING_GOLD=10

# 初始生命值
GAME_STARTING_HEALTH=100

# -----------------------------------------------------------------------------
# 日志配置
# -----------------------------------------------------------------------------
# 日志级别: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# 日志格式: json | text
# 生产环境建议 json，开发环境建议 text
LOG_FORMAT=text

# 日志文件路径（相对于项目根目录）
LOG_FILE=logs/app.log

# 日志文件最大大小（MB）
LOG_MAX_SIZE=10

# 日志备份数量
LOG_BACKUP_COUNT=5

# -----------------------------------------------------------------------------
# Docker 镜像版本
# -----------------------------------------------------------------------------
# 用于 docker-compose 镜像标签
VERSION=latest

# -----------------------------------------------------------------------------
# 开发工具端口（仅开发环境）
# -----------------------------------------------------------------------------
# Debugpy 调试端口
DEBUG_PORT=5678

# Adminer 数据库管理端口
ADMINER_PORT=8080

# Redis Commander 端口
REDIS_COMMANDER_PORT=8081

# =============================================================================
# 生产环境额外建议
# =============================================================================
# 1. 使用 Docker Secrets 替代明文密码：
#    DB_PASSWORD_FILE=/run/secrets/db_password
#
# 2. 使用外部密钥管理服务（如 HashiCorp Vault）
#
# 3. 启用 HTTPS（配置反向代理如 Nginx）
#
# 4. 配置日志收集（如 ELK Stack）
#
# 5. 启用监控和告警（如 Prometheus + Grafana）
#
# 6. 定期备份数据库
#
# 7. 配置防火墙规则
# =============================================================================
