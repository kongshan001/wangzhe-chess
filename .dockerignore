# =============================================================================
# 王者之奕 - Docker 忽略文件
# =============================================================================
# 定义构建上下文时忽略的文件和目录
# 减少构建上下文大小，加快构建速度
# =============================================================================

# -----------------------------------------------------------------------------
# 版本控制
# -----------------------------------------------------------------------------
.git
.gitignore
.gitattributes
.github

# -----------------------------------------------------------------------------
# Python 缓存和编译文件
# -----------------------------------------------------------------------------
__pycache__
*.py[cod]
*$py.class
*.so
.Python
*.egg-info
*.egg
.eggs
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# -----------------------------------------------------------------------------
# 虚拟环境
# -----------------------------------------------------------------------------
.venv
venv
ENV
env
.env.local

# -----------------------------------------------------------------------------
# IDE 和编辑器
# -----------------------------------------------------------------------------
.idea
.vscode
*.swp
*.swo
*~
.project
.pydevproject
.settings
*.sublime-workspace
*.sublime-project

# -----------------------------------------------------------------------------
# 测试和覆盖率
# -----------------------------------------------------------------------------
.pytest_cache
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.hypothesis/

# -----------------------------------------------------------------------------
# 文档
# -----------------------------------------------------------------------------
docs/
*.md
!README.md

# -----------------------------------------------------------------------------
# 本地数据和日志
# -----------------------------------------------------------------------------
data/
logs/
*.log
*.sql
*.sqlite
*.db

# -----------------------------------------------------------------------------
# Docker 相关
# -----------------------------------------------------------------------------
docker-compose*.yml
.docker/
Dockerfile*
.dockerignore

# -----------------------------------------------------------------------------
# CI/CD 配置
# -----------------------------------------------------------------------------
.gitlab-ci.yml
.travis.yml
Jenkinsfile
.azure-pipelines.yml

# -----------------------------------------------------------------------------
# 其他
# -----------------------------------------------------------------------------
.env*
!.env.example
*.bak
*.tmp
*.temp
.DS_Store
Thumbs.db
*.pem
*.key
*.crt

# -----------------------------------------------------------------------------
# 资产文件（如果不需要在镜像中）
# -----------------------------------------------------------------------------
# assets/
# *.png
# *.jpg
# *.gif
# *.mp3
# *.mp4

# -----------------------------------------------------------------------------
# 脚本（可选：如果不需要在镜像中）
# -----------------------------------------------------------------------------
scripts/
Makefile
