          "timeout": 60,
          "skip_text": "暂时跳过",
          "complete_text": "很好！商店已经刷新，现在有新的英雄可以选择了。"
        },
        {
          "step_id": "basic_6",
          "order": 6,
          "title": "出售英雄",
          "description": "学习如何出售不需要的英雄",
          "detail": "如果英雄不符合你的阵容策略，可以将他出售换取金币。拖动英雄到出售区域即可。1星英雄按原价出售，2星/3星英雄出售价格更优。",
          "action": "sell_hero",
          "action_target": "sell_area",
          "action_params": {
