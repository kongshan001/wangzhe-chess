          "timeout": 30,
          "complete_text": "太棒了！现在你能看到商店中的英雄了。"
        },
        {
          "step_id": "basic_3",
          "order": 3,
          "title": "购买第一个英雄",
          "description": "购买一个1费英雄开始你的冒险",
          "detail": "点击英雄卡片即可购买。1费英雄价格最便宜（1金币），适合开局时积累。购买3个相同英雄可以合成更高星级！",
          "action": "buy_hero",
          "action_target": "shop_hero_slot_0",
          "action_params": {
            "cost_limit": 1,
            "tip": "点击任意一个1金币的英雄"
