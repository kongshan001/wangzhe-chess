      "tutorial_type": "basic_operation",
      "name": "新手入门",
      "description": "学习王者之奕的基础操作，包括购买英雄、出售英雄和刷新商店",
      "steps": [
        {
          "step_id": "basic_1",
          "order": 1,
          "title": "欢迎来到王者之奕！",
          "description": "这是一款策略对战游戏，让我们开始学习基础操作吧！",
          "detail": "在王者之奕中，你需要组建强大的阵容，与其他玩家进行策略对决。首先让我们了解游戏界面。",
          "action": "click",
          "action_target": "btn_start_tutorial",
          "highlights": [
            {
              "target": "game_board",
              "shape": "rect",
              "animation": "pulse",
              "tip_text": "这是你的战斗区域",
