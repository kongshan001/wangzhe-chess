              "tip_text": "放置在这里",
              "tip_position": "bottom",
              "block_others": false
            }
          ],
          "timeout": 60,
          "complete_text": "完美！你的英雄已经就位，准备好战斗了！"
        },
        {
          "step_id": "basic_5",
          "order": 5,
          "title": "刷新商店",
          "description": "使用2金币刷新商店，寻找新的英雄",
          "detail": "如果商店中没有你想要的英雄，可以花费2金币刷新商店，重新抽取5个英雄。新手期建议优先购买能合成2星的英雄。",
          "action": "refresh_shop",
          "action_target": "btn_refresh_shop",
          "highlights": [
            {
              "target": "btn_refresh_shop",
