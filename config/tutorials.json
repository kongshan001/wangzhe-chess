          "timeout": 60,
          "complete_text": "恭喜！你成功购买了第一个英雄！"
        },
        {
          "step_id": "basic_4",
          "order": 4,
          "title": "将英雄放置到战场",
          "description": "把英雄从备战席拖放到战场上",
          "detail": "购买的英雄会先出现在备战席。你需要将他们拖放到战场才能参与战斗。每个英雄都有自己的羁绊属性，合理搭配会获得强力加成！",
          "action": "place_hero",
          "action_target": "bench_slot_0",
          "action_params": {
            "target_area": "board"
          },
          "highlights": [
            {
              "target": "bench_slot_0",
              "shape": "rect",
              "animation": "pulse",
