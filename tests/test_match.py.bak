"""
王者之奕 - 匹配系统完整测试
"""

import pytest
from server.match.queue import MatchQueue, MatchRequest, PlayerInfo
from server.match.elo import EloCalculator
from server.match.rating import RatingSystem, RatingTier, PlayerRating


# ============================================================================
# 测试数据
# ============================================================================

@pytest.fixture
def sample_players():
    """示例玩家数据"""
    return [
        PlayerInfo(player_id="p1", rating=1200, player_level=3),
        PlayerInfo(player_id="p2", rating=1180, player_level=3),
        PlayerInfo(player_id="p3", rating=1250, player_level=4),
        PlayerInfo(player_id="p4", rating=1220, player_level=3),
        PlayerInfo(player_id="p5", rating=1190, player_level=3),
    ]


# ============================================================================
# MatchQueue 测试
# ============================================================================

class TestMatchQueue:
    """匹配队列测试"""
    
    def test_add_player(self, sample_players):
        """测试添加玩家到队列"""
        queue = MatchQueue()
        
        for player in sample_players:
            queue.add_player(player)
        
        assert queue.get_queue_size(sample_players[0].rating) == 5
    
    def test_remove_player(self, sample_players):
        """测试从队列移除玩家"""
        queue = MatchQueue()
        
        for player in sample_players:
            queue.add_player(player)
        
        queue.remove_player(sample_players[0].player_id)
        
        assert queue.get_queue_size(sample_players[0].rating) == 4
    
    def test_find_match_exact_rating(self, sample_players):
        """测试精确匹配"""
        queue = MatchQueue()
        
        for player in sample_players:
            queue.add_player(player)
        
        match = queue.find_match(sample_players[0].player_id, rating_range=50)
        
        # 应该找到匹配（p1 和 p2 接近）
        assert match is not None
        assert len(match.players) >= 2
    
    def test_expand_search_range(self, sample_players):
        """测试扩大搜索范围"""
        queue = MatchQueue()
        
        for player in sample_players:
            queue.add_player(player)
        
        # 等待时间越长，搜索范围越大
        initial_range = 50
        expanded_range = queue.get_search_range(wait_time_ms=30000, initial_range=initial_range)
        
        assert expanded_range > initial_range
    
    def test_timeout_handling(self, sample_players):
        """测试超时处理"""
        queue = MatchQueue()
        queue.set_timeout_ms(30000)  # 30秒超时
        
        for player in sample_players:
            queue.add_player(player)
        
        # 模拟超时
        import time
        start = time.time()
        match = queue.find_match_with_timeout(sample_players[0].player_id)
        elapsed = time.time() - start
        
        assert elapsed >= 30.0


# ============================================================================
# EloCalculator 测试
# ============================================================================

class TestEloCalculator:
    """ELO系统测试"""
    
    def test_calculate_elo_win(self):
        """测试胜利的ELO计算"""
        calculator = EloCalculator()
        
        player_a = PlayerRating(player_id="p1", rating=1200)
        player_b = PlayerRating(player_id="p2", rating=1200)
        
        # 玩家A获胜
        new_a, new_b = calculator.calculate(player_a, player_b, player_a_wins=True)
        
        assert new_a > 1200  # 获胜方增加
        assert new_b < 1200  # 失败方减少
    
    def test_calculate_elo_loss(self):
        """测试失败的ELO计算"""
        calculator = EloCalculator()
        
        player_a = PlayerRating(player_id="p1", rating=1200)
        player_b = PlayerRating(player_id="p2", rating=1200)
        
        # 玩家A失败
        new_a, new_b = calculator.calculate(player_a, player_b, player_a_wins=False)
        
        assert new_a < 1200  # 失败方减少
        assert new_b > 1200  # 获胜方增加
    
    def test_k_factor_adjustment(self):
        """测试K值调整"""
        calculator = EloCalculator()
        
        # 高玩家使用较小K值（分数变化更慢）
        high_player = PlayerRating(player_id="high", rating=2000, total_matches=100)
        _, new_high = calculator.calculate(high_player, PlayerRating("low", 1000, total_matches=10), player_a_wins=True)
        
        assert abs(new_high - 2000) < 20  # 高玩家K值小
    
    def test_expected_score(self):
        """测试期望分数"""
        calculator = EloCalculator()
        
        player_a = PlayerRating(player_id="p1", rating=1200)
        player_b = PlayerRating(player_id="p2", rating=1200)
        
        expected = calculator.get_expected_score(player_a.rating, player_b.rating)
        
        assert 0 <= expected <= 1
        assert expected == 0.5  # 相同等级期望50%胜率


# ============================================================================
# RatingSystem 测试
# ============================================================================

class TestRatingSystem:
    """段位系统测试"""
    
    def test_tier_assignment(self):
        """测试段位分配"""
        system = RatingSystem()
        
        # 测试不同段位
        ratings = [800, 950, 1100, 1250, 1400, 1550, 1700, 1850, 2000]
        
        for rating in ratings:
            tier = system.get_tier(rating)
            assert tier is not None
    
    def test_promotion(self):
        """测试升段"""
        system = RatingSystem()
        
        player = PlayerRating(player_id="p1", rating=1199, tier=system.get_tier(1199))
        
        # 胜利后升段
        player.rating = 1201
        new_tier = system.get_tier(1201)
        
        assert new_tier.tier_id > player.tier.tier_id
    
    def test_demotion(self):
        """测试降段"""
        system = RatingSystem()
        
        player = PlayerRating(player_id="p1", rating=1201, tier=system.get_tier(1201))
        
        # 失败后降段
        player.rating = 1199
        new_tier = system.get_tier(1199)
        
        assert new_tier.tier_id < player.tier.tier_id
    
    def test_star_system(self):
        """测试星级系统"""
        system = RatingSystem()
        
        tier = system.get_tier(1000)
        player = PlayerRating(player_id="p1", rating=1000, stars=2, tier=tier)
        
        # 胜利后升星
        player.rating = 1050
        new_stars = system.calculate_stars(player.rating, tier)
        
        assert new_stars >= 2
    
    def test_protection_mechanism(self):
        """测试保级机制"""
        system = RatingSystem()
        
        # 保级规则
        player = PlayerRating(player_id="p1", rating=1201, tier=system.get_tier(1201))
        
        # 即使失败也不降级（例如首次进入新段位）
        should_demote = system.should_demote(player, tier_changed=False)
        
        assert not should_demote


if __name__ == "__main__":
    pytest.main([__file__, "-v", "--tb=short"])
